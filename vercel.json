{
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    { "source": "/plans", "destination": "/plans.html" },
    { "source": "/carpet", "destination": "/carpet-cleaning.html" },
    { "source": "/shoes", "destination": "/shoe-cleaning.html" },
    { "source": "/upholstery", "destination": "/upholstery-cleaning.html" },
    { "source": "/vacation", "destination": "/vacation-rental.html" },
    { "source": "/carpet-campaign", "destination": "/a7-carpet-campaign/index.html" },
    { "source": "/command-center", "destination": "/a7-command-center.html" },
    { "source": "/comforter", "destination": "/comforter-cleaning.html" },
    { "source": "/comforter-v2", "destination": "/comforter-cleaning-v2.html" },
    { "source": "/comforter-v3", "destination": "/comforter-cleaning-v3.html" },
    { "source": "/comforter-thanks", "destination": "/comforter-thanks.html" },
    { "source": "/comforter-v4", "destination": "/comforter-cleaning-v4.html" },
    { "source": "/comforter-v5", "destination": "/comforter-cleaning-v5.html" },
    { "source": "/comforter-v6", "destination": "/comforter-cleaning-v6.html" },
    { "source": "/premium", "destination": "/premium.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/laundry-service-orlando", "destination": "/blog/laundry-service-orlando.html" },
    { "source": "/blog/how-to-clean-comforter", "destination": "/blog/how-to-clean-comforter.html" },
    { "source": "/blog/vacation-rental-laundry-orlando", "destination": "/blog/vacation-rental-laundry-orlando.html" },
    { "source": "/blog/same-day-laundry-orlando", "destination": "/blog/same-day-laundry-orlando.html" },
    { "source": "/blog/laundry-kissimmee", "destination": "/blog/laundry-kissimmee.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.+\\.(?:jpg|png|svg|ico))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
